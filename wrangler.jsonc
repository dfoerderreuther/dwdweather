{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dwd-climate-almanac",
  "main": "./src/worker/index.js",
  "compatibility_date": "2025-04-01",
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
